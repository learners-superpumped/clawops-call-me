{
  "name": "callme",
  "version": "3.1.0",
  "description": "Claude가 입력이 필요하거나 진행 상황을 보고할 때 전화를 겁니다",
  "author": {
    "name": "learners-superpumped",
    "url": "https://github.com/learners-superpumped"
  },
  "repository": "https://github.com/learners-superpumped/clawops-call-me",
  "license": "MIT",
  "keywords": ["phone", "voice", "calls", "input"],
  "skills": "./skills",
  "mcpServers": {
    "callme": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "-m",
        "callme",
        "--root",
        "${CLAUDE_PLUGIN_ROOT}"
      ],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "VIRTUAL_ENV": ""
      }
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "SILENTLY evaluate if you should call the user. ONLY use initiate_call if you completed significant work and need to discuss next steps, or are genuinely blocked. Do NOT output any text - either call or do nothing."
          }
        ]
      }
    ]
  }
}
