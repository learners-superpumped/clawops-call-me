# ClawOps CallMe 환경변수 설정
# https://platform.claw-ops.com 에서 가입 후 설정

# ── 필수 ──────────────────────────────────────────────

# ClawOps Account ID (API & Webhooks 페이지에서 복사)
CALLME_PHONE_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx

# ClawOps API 키 (API & Webhooks > + 새 키 생성, 한 번만 표시)
CALLME_PHONE_API_KEY=sk_your_api_key

# Claude가 발신하는 전화번호 (전화번호 > + 번호 추가에서 등록)
CALLME_PHONE_NUMBER=07052358010

# Claude가 전화할 번호
CALLME_USER_PHONE_NUMBER=01012345678

# OpenAI API 키 (음성 인식 STT + 음성 합성 TTS)
CALLME_OPENAI_API_KEY=sk-xxx

# ── 선택 ──────────────────────────────────────────────

# ClawOps API URL (기본값: https://api.claw-ops.com)
# CALLME_CLAWOPS_BASE_URL=https://api.claw-ops.com

# TTS 음성 (기본값: onyx, 옵션: alloy, echo, fable, onyx, nova, shimmer)
# CALLME_TTS_VOICE=onyx

# 발화 종료 감지 무음 시간 (기본값: 800ms)
# CALLME_STT_SILENCE_DURATION_MS=800

# 사용자 음성 대기 타임아웃 (기본값: 180000ms = 3분)
# CALLME_TRANSCRIPT_TIMEOUT_MS=180000

# 데몬 제어 API 포트 (기본값: 3334)
# CALLME_CONTROL_PORT=3334

# ── 인바운드 콜 (선택) ────────────────────────────────

# 인바운드 콜 활성화
# CALLME_INBOUND_ENABLED=true

# 인바운드 콜에서 Claude CLI가 실행되는 프로젝트 디렉토리
# CALLME_WORKSPACE_DIR=/path/to/your/project

# 추가 허용 전화번호 (쉼표 구분, E.164 형식)
# CALLME_INBOUND_WHITELIST=+821098765432,+821055551234

# 인바운드 세션의 Claude Code 권한 모드 (기본값: plan)
# CALLME_INBOUND_PERMISSION_MODE=plan

# 최대 동시 인바운드 콜 수 (기본값: 1)
# CALLME_INBOUND_MAX_CALLS=1
